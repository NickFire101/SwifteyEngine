```gitignore
# ==========================================================
# SwifteyEngine
# .gitignore
# Supports:
# - iOS
# - iPadOS
# - macOS
# - Mac Catalyst
# ==========================================================

# ----------------------------------------------------------
# macOS
# ----------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# ----------------------------------------------------------
# Swift Package Manager
# ----------------------------------------------------------
.build/
.swiftpm/

# Uncomment if you don't want to commit Package.resolved
# Package.resolved

# ----------------------------------------------------------
# Xcode
# ----------------------------------------------------------
DerivedData/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcuserdatad/
*.xcuserstate
*.xccheckout
*.xcscmblueprint

# ----------------------------------------------------------
# Swift Playgrounds
# ----------------------------------------------------------
timeline.xctimeline
playground.xcworkspace

# ----------------------------------------------------------
# Logs & Temporary Files
# ----------------------------------------------------------
*.log
*.tmp
*.temp
*.swp
*.swo

# ----------------------------------------------------------
# Build Outputs
# ----------------------------------------------------------
build/
Build/
dist/
out/
Release/
Debug/

# ----------------------------------------------------------
# Code Coverage
# ----------------------------------------------------------
*.profraw
*.profdata
coverage/

# ----------------------------------------------------------
# AI Models (Keep repository lightweight)
# ----------------------------------------------------------
Models/
*.gguf
*.ggml
*.bin
*.onnx
*.mlmodel
*.mlpackage
*.mlmodelc
*.safetensors

# ----------------------------------------------------------
# Datasets
# ----------------------------------------------------------
Datasets/
dataset/
data/

# ----------------------------------------------------------
# Environment Files
# ----------------------------------------------------------
.env
.env.*

# ----------------------------------------------------------
# IDEs
# ----------------------------------------------------------
.vscode/
.idea/

# ----------------------------------------------------------
# Generated Documentation
# ----------------------------------------------------------
docs/generated/

# ----------------------------------------------------------
# Test Results
# ----------------------------------------------------------
TestResults/
```
